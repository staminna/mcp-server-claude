# Source files (TypeScript will be compiled to dist/)
src/
*.ts
!*.d.ts

# Development and build files
.env
.env.example
.env.*
tsconfig.json
.eslintrc.*
.prettierrc.*
.windsurfrc

# Development dependencies and tools
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Git files
.git/
.gitignore
.gitattributes

# Testing and coverage
coverage/
.nyc_output/
*.lcov

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Documentation source (keep README.md)
docs/
*.md
!README.md

# Scripts and setup files
setup-local-https.sh
*.sh

# Lock files (let users choose their package manager)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build artifacts that shouldn't be published
build/
lib/
out/

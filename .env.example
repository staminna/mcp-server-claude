DIRECTUS_URL=https://your-directus-instance.com
DIRECTUS_TOKEN=your_DIRECTUS_TOKEN_here
DIRECTUS_TIMEOUT=30000
DIRECTUS_RETRIES=3
DIRECTUS_WEBSOCKET=true
NODE_ENV=development

# HTTPS Certificate Configuration (optional)
# Path to Certificate Authority file
# DIRECTUS_HTTPS_CA=/path/to/ca-certificate.pem
# Path to client certificate file
# DIRECTUS_HTTPS_CERT=/path/to/client-certificate.pem
# Path to private key file
# DIRECTUS_HTTPS_KEY=/path/to/private-key.pem
# Path to PFX/PKCS12 file
# DIRECTUS_HTTPS_PFX=/path/to/certificate.pfx
# Passphrase for private key or PFX
# DIRECTUS_HTTPS_PASSPHRASE=your_passphrase_here
# Reject unauthorized certificates (default: true)
# DIRECTUS_HTTPS_REJECT_UNAUTHORIZED=false
# Server name for SNI
# DIRECTUS_HTTPS_SERVERNAME=your-server-name.com
{
  "name": "@staminna/directus-mcp-server",
  "version": "1.3.0",
  "description": "Enhanced MCP server for Directus with TypeScript, WebSocket, and full API coverage",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "type": "module",
  "bin": {
    "directus-mcp": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/staminna/mcp-server-claude.git"
  },
  "homepage": "https://github.com/staminna/mcp-server-claude#readme",
  "bugs": {
    "url": "https://github.com/staminna/mcp-server-claude/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build",
    "prepack": "npm run build"
  },
  "keywords": [
    "directus",
    "mcp",
    "model-context-protocol",
    "typescript",
    "websocket",
    "api",
    "claude",
    "ai",
    "cms",
    "real-time"
  ],
  "author": "Jorge Domingues Nunes",
  "license": "MIT",
  "dependencies": {
    "@directus/sdk": "^20.0.3",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "axios": "^1.11.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.6.1",
    "form-data": "^4.0.4",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/form-data": "^2.5.2",
    "@types/node": "^22.18.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.2"
  },
  "exports": {
    ".": {
      "import": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    },
    "./server": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}

{
  "name": "directus-mcp-server",
  "version": "1.0.0",
  "description": "Enhanced MCP server for Directus with TypeScript, WebSocket, and full API coverage",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "directus-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "directus",
    "mcp",
    "model-context-protocol",
    "typescript",
    "websocket",
    "api"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "axios": "^1.7.9",
    "ws": "^8.18.0",
    "dotenv": "^16.4.7",
    "form-data": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "@types/form-data": "^2.5.0",
    "typescript": "^5.7.2",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}